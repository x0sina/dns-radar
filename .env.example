# Required: base domain used by generated long TXT probe names.
# Example zone: example.com
# Recommended record: wildcard TXT at *.probe.example.com
TXT_BASE_DOMAIN=probe.example.com

# Recommended: token that must appear in TXT responses.
TXT_EXPECTED_TOKEN=slipstream-ok

# Input/output files.
# If running from repository root, keep these values.
IPS_FILE=ips.txt
SUCCESS_FILE=good.txt
SUCCESS_CSV_FILE=good.csv

# Scanner behavior.
DNS_QUERY_COUNT=5
DNS_MIN_SUCCESS=4
DNS_MIN_LENGTH=152
DNS_MAX_LENGTH=253
DNS_MIXED_CASE=true

# Timeouts and worker concurrency.
PING_TIMEOUT_MS=2000
DNS_TIMEOUT_MS=2000
SCAN_CONCURRENCY=64
